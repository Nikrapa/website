<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Agdasima:wght@400;700&display=swap" rel="stylesheet">
    <title>Blog</title>
    <style>
        /* Global Styling */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: "Agdasima", sans-serif;
            background: url('galaxy1.jpg') no-repeat center center/cover fixed;
            color: #333;
            min-height: 100vh;
        }

        /* ── Nav ── */
        nav {
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 50px;
            position: fixed;
            top: 0;
            left: 0;
            z-index: 200;
        }

        nav .logo h1 {
            color: white;
            font-size: 24px;
        }

        nav ul {
            display: flex;
            list-style: none;
            font-size: 30px;
        }

        nav ul li {
            margin-left: 20px;
        }

        nav ul li a {
            color: white;
            text-decoration: none;
            font-weight: 400;
        }

        @media (max-width: 768px) {
            nav { padding: 10px 20px; }
            nav ul { font-size: 20px; }
            nav ul li { margin-left: 12px; }
        }

        @media (max-width: 480px) {
            nav ul { font-size: 17px; }
            nav ul li { margin-left: 8px; }
        }

        /* Container */
        .blog-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 80px 40px 40px;
        }

        h1.blog-title {
            text-align: center;
            font-size: 36px;
            margin-bottom: 40px;
            color: #ffffff;
        }

        /* Blog Post Cards */
        .post-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 20px;
        }

        .post-card {
            background-color: #fff;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s ease;
            display: flex;
            flex-direction: column;
            color: inherit;
            text-decoration: none;
            cursor: pointer;
        }

        .post-card:hover {
            transform: translateY(-5px);
        }

        .post-image {
            height: 200px;
            overflow: hidden;
        }

        .post-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.3s ease;
        }

        .post-card:hover .post-image img {
            transform: scale(1.05);
        }

        .post-content {
            padding: 20px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .post-content h3 {
            font-size: 30px;
            margin-bottom: 10px;
        }

        .post-meta {
            font-size: 14px;
            color: #777;
            margin-bottom: 15px;
        }

        .post-meta span {
            margin-right: 10px;
        }

        .post-excerpt {
            font-size: 18px;
            color: #555;
            line-height: 1.6;
        }

        /* Modal Styling */
        .modal {
            display: none; /* Hidden by default */
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.7); /* Semi-transparent background */
            justify-content: center;
            align-items: center;
        }

        .modal-content {
            background-color: #fff;
            padding: 20px;
            border-radius: 10px;
            width: 60%;
            max-width: 800px;
            max-height: 80%;
            overflow-y: auto;
        }

        .close-btn {
            background-color: #f44336;
            color: white;
            border: none;
            padding: 10px 20px;
            cursor: pointer;
            border-radius: 5px;
            font-size: 16px;
            float: right;
        }

        .close-btn:hover {
            background-color: #d32f2f;
        }

        @media (max-width: 768px) {
            .post-grid {
                grid-template-columns: 1fr;
            }

            .modal-content {
                width: 90%;
            }
        }
        /* ── Footer ── */
        footer {
            background-color: #000;
            color: #fff;
            position: relative;
            padding: 70px 0 0;
            font-family: "Agdasima", sans-serif;
        }
        footer::before {
            content: '';
            display: block;
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 3px;
            background: linear-gradient(90deg, #0d0d0d, #4f46e5, #9333ea, #4f46e5, #0d0d0d);
        }
        .footer-inner {
            max-width: 1100px;
            margin: 0 auto;
            padding: 0 40px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 60px;
            align-items: start;
        }
        .footer-brand h2 {
            font-size: 42px;
            font-weight: 700;
            letter-spacing: 2px;
            background: linear-gradient(135deg, #fff 40%, #9333ea);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 6px;
        }
        .footer-brand .tagline { font-size: 16px; color: #888; letter-spacing: 1px; margin-bottom: 32px; }
        .footer-info-row { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; font-size: 17px; color: #bbb; }
        .footer-info-row i { color: #7c3aed; font-size: 18px; width: 20px; text-align: center; }
        .footer-info-row a { color: #bbb; text-decoration: none; transition: color 0.3s; }
        .footer-info-row a:hover { color: #fff; }
        .social-pills { display: flex; gap: 12px; margin-top: 30px; flex-wrap: wrap; }
        .social-pills a {
            display: flex; align-items: center; gap: 8px;
            padding: 9px 20px;
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 50px; color: #ccc; text-decoration: none; font-size: 15px;
            transition: all 0.3s ease;
            background: rgba(255,255,255,0.04); backdrop-filter: blur(4px);
        }
        .social-pills a:hover {
            background: rgba(147,51,234,0.2); border-color: #9333ea; color: #fff;
            box-shadow: 0 0 18px rgba(147,51,234,0.35); transform: translateY(-2px);
        }
        .social-pills a i { font-size: 16px; }
        .footer-form-wrap {
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 16px; padding: 36px 32px;
            backdrop-filter: blur(8px);
            box-shadow: 0 8px 40px rgba(0,0,0,0.5);
        }
        .footer-form-wrap h3 { font-size: 24px; font-weight: 700; margin-bottom: 6px; color: #fff; }
        .footer-form-wrap p.form-sub { font-size: 15px; color: #777; margin-bottom: 24px; }
        .footer-form-wrap input,
        .footer-form-wrap textarea {
            width: 100%; background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px; padding: 12px 16px;
            color: #fff; font-family: "Agdasima", sans-serif;
            font-size: 16px; margin-bottom: 14px;
            outline: none; transition: border-color 0.3s, box-shadow 0.3s;
        }
        .footer-form-wrap input::placeholder,
        .footer-form-wrap textarea::placeholder { color: #555; }
        .footer-form-wrap input:focus,
        .footer-form-wrap textarea:focus { border-color: #7c3aed; box-shadow: 0 0 0 3px rgba(124,58,237,0.2); }
        .footer-form-wrap textarea { height: 110px; resize: vertical; }
        .footer-form-wrap button {
            width: 100%; padding: 13px; border: none; border-radius: 8px;
            background: linear-gradient(135deg, #4f46e5, #9333ea);
            color: #fff; font-family: "Agdasima", sans-serif;
            font-size: 18px; font-weight: 700; letter-spacing: 1px; cursor: pointer;
            transition: opacity 0.3s, transform 0.2s, box-shadow 0.3s;
            box-shadow: 0 4px 20px rgba(124,58,237,0.4);
        }
        .footer-form-wrap button:hover { opacity: 0.9; transform: translateY(-1px); box-shadow: 0 6px 28px rgba(124,58,237,0.6); }
        .footer-bottom {
            margin-top: 60px;
            border-top: 1px solid rgba(255,255,255,0.07);
            padding: 20px 40px; max-width: 1100px;
            margin-left: auto; margin-right: auto;
            display: flex; justify-content: space-between;
            align-items: center; font-size: 14px; color: #444;
        }
        .footer-bottom a { color: #555; text-decoration: none; transition: color 0.3s; }
        .footer-bottom a:hover { color: #9333ea; }
        @media (max-width: 768px) {
            .footer-inner { grid-template-columns: 1fr; gap: 40px; padding: 0 24px; }
            footer { padding: 50px 0 0; }
            .footer-brand h2 { font-size: 34px; }
            .footer-bottom { flex-direction: column; gap: 8px; text-align: center; padding: 20px 24px; }
        }
        @media (max-width: 480px) {
            .footer-form-wrap { padding: 24px 18px; }
            .social-pills { gap: 8px; }
            .social-pills a { padding: 8px 14px; font-size: 14px; }
            .footer-info-row { font-size: 15px; word-break: break-word; }
        }
    </style>
</head>
